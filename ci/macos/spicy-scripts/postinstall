#!/bin/bash
set -e

APP="/Applications/GorizontVS-VDI.app"
SPICE="$APP/Contents/Resources/spice"
FRAMEWORKS="$APP/Contents/Frameworks"

if [ ! -d "$APP" ]; then
  exit 0
fi

mkdir -p /usr/local/bin

cat > /usr/local/bin/spicy <<'EOF'
#!/bin/bash
set -e

APP="/Applications/GorizontVS-VDI.app"
SPICE="$APP/Contents/Resources/spice"
FRAMEWORKS="$APP/Contents/Frameworks"

mkdir -p "$HOME/Library/Application Support/GorizontVS" || true

export PATH="$SPICE/bin:/usr/bin:/bin:/usr/sbin:/sbin"

export DYLD_FALLBACK_LIBRARY_PATH="$FRAMEWORKS:$SPICE/lib:$SPICE/lib/gstreamer-1.0:/usr/lib"

export GST_PLUGIN_PATH_1_0="$SPICE/lib/gstreamer-1.0"
export GST_PLUGIN_SCANNER="$SPICE/libexec/gstreamer-1.0/gst-plugin-scanner"
export GST_REGISTRY_REUSE_PLUGIN_SCANNER=1
export GST_REGISTRY="$HOME/Library/Application Support/GorizontVS/gstreamer-registry.bin"

export GIO_MODULE_DIR="$SPICE/lib/gio/modules"
export GI_TYPELIB_PATH="$SPICE/lib/girepository-1.0"

export GDK_PIXBUF_MODULEDIR="$SPICE/lib/gdk-pixbuf-2.0/2.10.0/loaders"
export GDK_PIXBUF_MODULE_FILE="$SPICE/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"

export XDG_DATA_DIRS="$SPICE/share:/usr/local/share:/usr/share"
export GTK_DATA_PREFIX="$SPICE"
export GTK_EXE_PREFIX="$SPICE"
export GTK_PATH="$SPICE"

exec "$SPICE/bin/spicy" "$@"
EOF

chmod +x /usr/local/bin/spicy

exit 0
