#!/bin/bash
set -e

APP="/Applications/GorizontVS-VDI.app"

if [ ! -d "$APP" ]; then
  echo "postinstall: app not found: $APP"
  exit 0
fi

echo "postinstall: permissions only, do not touch Nuitka runtime"

if [ -f "$APP/Contents/MacOS/GorizontVS-VDI" ]; then
  /bin/chmod +x "$APP/Contents/MacOS/GorizontVS-VDI" || true
fi

if [ -d "$APP/Contents/Resources/spice/bin" ]; then
  /usr/bin/find "$APP/Contents/Resources/spice/bin" -type f -exec /bin/chmod +x {} + 2>/dev/null || true
fi

if [ -f "$APP/Contents/Resources/spice/libexec/gstreamer-1.0/gst-plugin-scanner" ]; then
  /bin/chmod +x "$APP/Contents/Resources/spice/libexec/gstreamer-1.0/gst-plugin-scanner" || true
fi

exit 0
